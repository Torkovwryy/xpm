{
  "name": "xpm-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "eXtensible Package Manager - The scalable, deterministic, and secure package manager.",
  "author": "XPM Core Team",
  "license": "MIT",
  "engines": {
    "node": ">=20.12.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "test": "echo 'Testing environment not yet initialized.'",
    "format": "prettier --write \"**/*.{ts,js,json,md,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md,yaml}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.59.4"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml}": [
      "prettier --write"
    ]
  }
}
